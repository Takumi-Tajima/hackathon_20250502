.container
  .d-flex.justify-content-between.align-items-center.mb-4
    %h1.fs-2 配送プラン詳細
    .btn-group
      = link_to '編集', edit_admins_delivery_plan_path(@delivery_plan), class: 'btn btn-outline-primary'
      = link_to '一覧に戻る', admins_delivery_plans_path, class: 'btn btn-outline-secondary'

  .card
    .card-body
      %dl.row
        %dt.col-sm-3 プラン名
        %dd.col-sm-9= @delivery_plan.name

        %dt.col-sm-3 説明
        %dd.col-sm-9= @delivery_plan.description.presence || '(未設定)'

        %dt.col-sm-3 配送頻度
        %dd.col-sm-9= @delivery_plan.delivery_frequency_text

        %dt.col-sm-3 価格
        %dd.col-sm-9= number_to_currency(@delivery_plan.price)

        %dt.col-sm-3 ステータス
        %dd.col-sm-9= @delivery_plan.published? ? '公開中' : '非公開'

        %dt.col-sm-3 作成日時
        %dd.col-sm-9= l @delivery_plan.created_at, format: :long

        %dt.col-sm-3 更新日時
        %dd.col-sm-9= l @delivery_plan.updated_at, format: :long
