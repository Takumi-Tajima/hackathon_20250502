.container.my-4
  .d-flex.justify-content-between.align-items-center.mb-4
    %h1.fs-2 契約中のプラン一覧
    = link_to '新しいプランを探す', users_delivery_plans_path, class: 'btn btn-outline-primary'

  - if @user_plans.exists?
    .table-responsive
      %table.table
        %thead
          %tr
            %th プラン名
            %th 配送頻度
            %th 料金
            %th ステータス
            %th
        %tbody
          - @user_plans.each do |plan|
            %tr
              %td= plan.delivery_plan.name
              %td= plan.delivery_plan.delivery_frequency_text
              %td= number_to_currency(plan.delivery_plan.price, unit: '¥', precision: 0)
              %td= plan.status_text
              %td.text-end
                - if plan.active?
                  = link_to 'キャンセル', users_user_plan_path(plan), 
                          data: { turbo_method: :delete, turbo_confirm: 'このプランをキャンセルしますか？' },
                          class: 'btn btn-sm btn-outline-danger'
  - else
    .alert.alert-info
      現在、契約中のプランはありません。
      = link_to 'プランを探す', users_delivery_plans_path, class: 'alert-link'
      から配送プランを選択してください。
